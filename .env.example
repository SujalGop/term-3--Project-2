# AI Study Companion — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env (with real keys) to source control.

# AI Provider (OpenAI-compatible — works with OpenAI, Azure OpenAI, Together AI, etc.)
VITE_AI_API_URL=https://api.openai.com/v1
VITE_AI_API_KEY=YOUR_OPENAI_API_KEY_HERE
VITE_AI_MODEL=gpt-4o

# For Anthropic Claude, set:
# VITE_AI_API_URL=https://api.anthropic.com/v1
# VITE_AI_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
# VITE_AI_MODEL=claude-3-5-sonnet-20241022
# (and update the Anthropic request format in src/services/aiService.js)
